rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS (The "Brain" of the Rules) ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- USER RULES (Profiles, Addresses, History, & Security) ---
    match /users/{userId} {
      // Admin can see everyone; Users can see their own profile
      allow read: if isOwner(userId) || isAdmin();
      
      // Admin can create delivery boys; Users can create their own profile
      allow create: if isAdmin() || isOwner(userId);

      // Admin can update everything; Users can update own info
      // Users CANNOT change: role, accountStatus (only admin/server)
      allow update: if isAdmin() || (
        isOwner(userId) && 
        !('role' in request.resource.data && request.resource.data.role != resource.data.role)
      );

      // Only Admin can delete users
      allow delete: if isAdmin();
      
      // --- Addresses ---
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // --- Browsing History ---
      match /history/{historyId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // --- WISHLIST ---
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      // --- GIFT CARDS SUBCOLLECTION ---
      match /giftCards/{giftCardId} {
        allow read: if isOwner(userId) || isAdmin();
        // Only admin can create/update/delete gift cards
        allow write: if isAdmin();
      }

      // --- WALLET (subcollection) ---
      // Balance is READ-ONLY for clients. Only server/admin can modify.
      // In production, replace client writes with Cloud Functions.
      match /wallets/{walletId} {
        allow read: if isOwner(userId) || isAdmin();
        // Allow create for wallet initialization
        allow create: if isOwner(userId) || isAdmin();
        // Users can update their own wallet (for client-side atomic transactions)
        // In production: restrict to Cloud Functions only
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if false; // NEVER delete wallets
      }
      
      // --- TRANSACTIONS (append-only ledger) ---
      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        // Transactions can be created but NEVER edited or deleted
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isAdmin(); // Only admin can update status (e.g., expire)
        allow delete: if false; // Immutable transaction log
      }
      
      // --- REWARDS ---
      match /rewards/{rewardId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin(); // For redemption
        allow delete: if false; // Never delete reward entries
      }
      
      // --- PAYMENT METHODS (Razorpay ready) ---
      match /paymentMethods/{methodId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin(); // Only admin can hard-delete
      }
      
      // --- LOGIN HISTORY (append-only security log) ---
      match /loginHistory/{entryId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if false; // Immutable
        allow delete: if isAdmin(); // Admin cleanup only
      }
      
      // --- SESSIONS ---
      match /sessions/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin(); // For termination
        allow delete: if isAdmin();
      }
      
      // --- TRUSTED DEVICES ---
      match /trustedDevices/{deviceId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }
      
      // --- AUDIT LOG (append-only) ---
      match /auditLog/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if false; // Immutable audit trail
        allow delete: if false; // Never delete audit logs
      }
    }
    
    // --- GIFT CARDS (global collection) ---
    match /giftCards/{cardId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated(); // For redemption
      allow delete: if isAdmin();
    }
    
    // --- REFUNDS (global collection) ---
    match /refunds/{refundId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin(); // Only admin processes refunds
      allow delete: if false;
    }
    
    // --- ADMIN WALLET LOG ---
    match /adminWalletLog/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false; // Immutable
      allow delete: if false;
    }
    
    // --- ACCOUNT DELETION REQUESTS ---
    match /accountDeletionRequests/{requestId} {
      // Allow list/query: users can query their own requests
      allow list: if isAuthenticated();
      // Allow get: users can read their own requests or admin can read all
      allow get: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // --- STORE MANAGEMENT (Products & Admin Data) ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin/{docId} {
      allow read, write: if isAdmin();
    }
    
    // --- CUSTOMER EXPERIENCE (Carts & Categories) ---
    match /carts/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /items/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- MARKETING (Banners) ---
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- COUPONS ---
    // Customers need to read coupons to apply them at checkout, and need to
    // bump `usedCount` by 1 after their order is created so admin limits stay
    // accurate. They must NOT be able to mutate any other coupon field.
    match /coupons/{couponId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['usedCount', 'updatedAt'])
        && request.resource.data.usedCount == resource.data.usedCount + 1
      );
    }
    
    // --- HOMEPAGE SHOWCASES ---
    match /showcases/{showcaseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- HOMEPAGE TESTIMONIALS ---
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- CUSTOMER REVIEWS ---
    match /reviews/{reviewId} {
      // Anyone can read approved reviews
      allow read: if true;
      // Authenticated users can create their own reviews
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // Only admin can update (approve/reject) or delete reviews
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // --- HOMEPAGE GALLERY ---
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- ORDER FULFILLMENT (Optimized for Delivery Partners with OTP Verification) ---
    match /orders/{orderId} {
      // Helper: Check if user is the assigned delivery partner
      function isAssignedDeliveryBoy() {
        return isAuthenticated() && resource.data.delivery_boy_id == request.auth.uid;
      }
      
      // Helper: Check if user is the order owner (customer)
      function isOrderOwner() {
        return isAuthenticated() && resource.data.userId == request.auth.uid;
      }
      
      // Helper: Validate status transitions for delivery workflow
      function isValidStatusTransition() {
        let currentStatus = resource.data.status;
        let newStatus = request.resource.data.status;
        
        // Delivery boy workflow: shipped/assigned → picked → outForDelivery → delivered
        return (currentStatus == 'shipped' && newStatus == 'picked') ||
               (currentStatus == 'assigned' && newStatus == 'picked') ||
               (currentStatus == 'picked' && newStatus == 'outForDelivery') ||
               (currentStatus == 'outForDelivery' && newStatus == 'delivered');
      }
      
      // Helper: Ensure OTP is only cleared when marking as delivered
      function isValidOTPUpdate() {
        let newStatus = request.resource.data.status;
        // Only allow OTP to be cleared (set to null) when status becomes 'delivered'
        return newStatus == 'delivered' ? 
          (request.resource.data.delivery_otp == null && request.resource.data.otp_verified == true) :
          true;
      }
      
      // Helper: Check if customer is cancelling their own order
      function isValidCancellation() {
        let currentStatus = resource.data.status;
        let newStatus = request.resource.data.status;
        // Customers can only cancel orders that are 'pending' or 'processing'
        return newStatus == 'cancelled' && 
               (currentStatus == 'pending' || currentStatus == 'processing') &&
               request.resource.data.cancelledBy == 'user';
      }
      
      // Helper: Check if customer is requesting a return for a delivered order
      function isValidReturnRequest() {
        let currentStatus = resource.data.status;
        let newStatus = request.resource.data.status;
        return currentStatus == 'delivered' && newStatus == 'returnRequested';
      }
      
      // READ: Admins see all; Customers see their orders; Delivery boys see assigned orders
      allow read: if isAuthenticated() && 
        (resource == null || isOrderOwner() || isAssignedDeliveryBoy() || isAdmin());
      
      // CREATE: Only authenticated users can create their own orders
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
        
      // UPDATE: Complex rules for different roles
      // - Admin can update anything
      // - Customers can cancel their own orders (pending/processing only)
      // - Customers can request returns for delivered orders
      // - Delivery boys can only update their assigned orders with valid status transitions
      allow update: if isAdmin() || 
        (isOrderOwner() && isValidCancellation()) ||
        (isOrderOwner() && isValidReturnRequest()) ||
        (isAssignedDeliveryBoy() && isValidStatusTransition() && isValidOTPUpdate());
      
      // DELETE: Only admin can delete orders
      allow delete: if isAdmin();

      // --- ORDER MESSAGES / IN-APP CHAT ---
      match /messages/{messageId} {
        function parentOrder() {
          return get(/databases/$(database)/documents/orders/$(orderId));
        }

        function isMessageOrderOwner() {
          return isAuthenticated() && parentOrder().data.userId == request.auth.uid;
        }

        function isCustomerMessageWrite() {
          return request.resource.data.authorType == 'customer'
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.visibility == 'customer'
            && request.resource.data.channel == 'chat';
        }

        allow read: if isAdmin() ||
          (isMessageOrderOwner() && resource.data.visibility == 'customer');

        allow create: if isAdmin() ||
          (isMessageOrderOwner() && isCustomerMessageWrite());

        allow update, delete: if isAdmin();
      }
    }

    // --- USER FCM TOKENS (web push) ---
    // Document ID = the FCM registration token; data: { uid, token, platform, userAgent, createdAt, updatedAt }
    match /userTokens/{token} {
      // Owner may create or update their own token document
      allow create, update: if isAuthenticated()
                            && request.resource.data.uid == request.auth.uid;
      // Owner may delete their own token (sign-out / unsubscribe)
      allow delete: if isAuthenticated()
                    && resource.data.uid == request.auth.uid;
      // Admin may read all tokens (for the broadcast UI); owner may read their own
      allow read: if isAdmin()
                  || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }

    // --- WHATSAPP OTP ARTIFACTS ---
    // Server-only collection. Hashed OTP records are written/verified through
    // the Vercel functions running with the firebase-admin SDK, which bypasses
    // these rules. Block all client access.
    match /whatsappOtps/{doc} {
      allow read, write: if false;
    }

    // --- MARKETING CAMPAIGNS (broadcasts: push + WhatsApp) ---
    // Admin-only. The /api/broadcast endpoint uses the admin SDK (bypasses
    // these rules) to write per-channel results back to the document.
    match /broadcastCampaigns/{campaignId} {
      allow read, write: if isAdmin();
    }

    // --- WHATSAPP TEMPLATE METADATA ---
    // Admin-managed list of approved Cloud-API template names + parameter
    // descriptions used by the Marketing Center composer. Templates themselves
    // are approved in Meta dashboard; this collection only stores metadata
    // for picker UX.
    match /whatsappTemplates/{templateId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // --- WHATSAPP INBOX (admin reply console) ---
    // Threaded conversation records populated by the /api/whatsapp-webhook
    // function (admin SDK). Admin-only client access.
    match /whatsappThreads/{threadId} {
      allow read, write: if isAdmin();
      match /messages/{msgId} {
        allow read, write: if isAdmin();
      }
    }

    // --- VIDEO CALL SIGNALLING ---
    // Two participants only: caller and callee. SDP offer/answer + ICE
    // candidates live for the duration of the call and are deleted on hangup.
    match /videoCalls/{callId} {
      allow create: if isAuthenticated()
                    && request.resource.data.callerUid == request.auth.uid;
      allow read, update, delete: if isAuthenticated()
                    && (resource.data.callerUid == request.auth.uid
                        || resource.data.calleeUid == request.auth.uid);
      match /callerCandidates/{cand} {
        allow read, write: if isAuthenticated()
                          && (get(/databases/$(database)/documents/videoCalls/$(callId)).data.callerUid == request.auth.uid
                              || get(/databases/$(database)/documents/videoCalls/$(callId)).data.calleeUid == request.auth.uid);
      }
      match /calleeCandidates/{cand} {
        allow read, write: if isAuthenticated()
                          && (get(/databases/$(database)/documents/videoCalls/$(callId)).data.callerUid == request.auth.uid
                              || get(/databases/$(database)/documents/videoCalls/$(callId)).data.calleeUid == request.auth.uid);
      }
    }

    // --- VIDEO CALL REQUESTS (demo booking) ---
    match /videoCallRequests/{reqId} {
      // Customer can create their own request
      allow create: if isAuthenticated()
                    && request.resource.data.customerUid == request.auth.uid;
      // Customer can read/update (cancel) their own requests
      allow read, update: if isAuthenticated()
                    && (resource.data.customerUid == request.auth.uid || isAdmin());
      // Only admin can delete
      allow delete: if isAdmin();
      // List-level: admins see all; customers query filtered by their uid
      allow list: if isAuthenticated();
    }
  }
}
